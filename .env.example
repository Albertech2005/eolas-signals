# ===================================================
# EOLAS Signals — Environment Configuration
# Copy to .env and fill in your values
# ===================================================

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eolas:eolas@postgres:5432/eolasdb
REDIS_URL=redis://redis:6379/0

# ── App ───────────────────────────────────────────
DEBUG=false
ENVIRONMENT=production

# CORS — add your frontend domain here
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]

# ── Telegram (required for alerts) ────────────────
# 1. Create bot: https://t.me/BotFather → /newbot
# 2. Get token and add to your channel as admin
# 3. Get channel ID from https://t.me/username or use @channelname
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=@your_channel_or_-100xxxxxxxxxxxx

# ── Exchange API Keys (optional — raises rate limits) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Coinglass free tier works without a key, but a key unlocks
# higher rate limits and more liquidation data
COINGLASS_API_KEY=

# ── Signal Engine Tuning ──────────────────────────
MIN_CONFIDENCE_SCORE=70         # Minimum score to generate a signal (0-100)
SIGNAL_COOLDOWN_MINUTES=15      # Min minutes between signals for same asset
SIGNAL_EVAL_INTERVAL_SECONDS=60 # How often engine runs
DATA_REFRESH_INTERVAL_SECONDS=10 # How often market data is fetched

# Trade SL/TP defaults (as decimal fractions)
DEFAULT_SL_PCT=0.02   # 2% stop loss
DEFAULT_TP1_PCT=0.03  # 3% take profit 1
DEFAULT_TP2_PCT=0.05  # 5% take profit 2

# ── EOLAS DEX ─────────────────────────────────────
EOLAS_BASE_URL=https://perps.eolas.fun
EOLAS_TRADE_PATH=/trade

# ── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_EOLAS_URL=https://perps.eolas.fun
NEXT_PUBLIC_TELEGRAM_CHANNEL=https://t.me/your_channel
